<Window x:Class="NetShaper.Gui.AskDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="NetShaper — Firewall Ask"
        Width="480" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Topmost="True"
        Background="{DynamicResource PanelBrush}">
  <DockPanel Margin="18">
    <Border DockPanel.Dock="Top" Background="#33FFC857" CornerRadius="8" Padding="10,6" Margin="0,0,0,14">
      <TextBlock Text="New network activity — choose what NetShaper should do"
                 Foreground="{DynamicResource WarnBrush}" FontWeight="SemiBold"/>
    </Border>

    <StackPanel DockPanel.Dock="Bottom" Margin="0,16,0,0">
      <UniformGrid Columns="2" Margin="0,0,0,8">
        <Button Content="Allow always" Style="{StaticResource AccentButton}" Margin="0,0,6,6" Click="AllowAlways_Click"
                ToolTip="Save Allow rule to policy and apply WFP if elevated"/>
        <Button Content="Block always" Style="{StaticResource DangerButton}" Margin="0,0,0,6" Click="BlockAlways_Click"
                ToolTip="Save Block rule to policy and apply WFP if elevated"/>
        <Button Content="Allow once" Margin="0,0,6,0" Click="AllowOnce_Click"
                ToolTip="This session only (temp WFP allow if elevated)"/>
        <Button Content="Block once" Margin="0,0,0,0" Click="BlockOnce_Click"
                ToolTip="This session only (temp WFP block if elevated)"/>
      </UniformGrid>
      <DockPanel>
        <Button Content="Skip (don't ask again this session)" DockPanel.Dock="Left" Click="Skip_Click"/>
        <TextBlock x:Name="ElevHint" DockPanel.Dock="Right" HorizontalAlignment="Right"
                   Foreground="{DynamicResource MutedBrush}" VerticalAlignment="Center" FontSize="11"/>
      </DockPanel>
    </StackPanel>

    <StackPanel>
      <TextBlock x:Name="TitleText" FontSize="16" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,0,0,8"/>
      <TextBlock x:Name="PathText" FontFamily="Consolas" FontSize="11" TextWrapping="Wrap"
                 Foreground="{DynamicResource MutedBrush}" Margin="0,0,0,12"/>
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="100"/>
          <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
          <RowDefinition/>
          <RowDefinition/>
          <RowDefinition/>
          <RowDefinition/>
          <RowDefinition/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="PID" Foreground="{DynamicResource MutedBrush}"/>
        <TextBlock x:Name="PidText" Grid.Row="0" Grid.Column="1"/>
        <TextBlock Grid.Row="1" Text="Protocol" Foreground="{DynamicResource MutedBrush}"/>
        <TextBlock x:Name="ProtoText" Grid.Row="1" Grid.Column="1"/>
        <TextBlock Grid.Row="2" Text="Local" Foreground="{DynamicResource MutedBrush}"/>
        <TextBlock x:Name="LocalText" Grid.Row="2" Grid.Column="1" TextWrapping="Wrap"/>
        <TextBlock Grid.Row="3" Text="Remote" Foreground="{DynamicResource MutedBrush}"/>
        <TextBlock x:Name="RemoteText" Grid.Row="3" Grid.Column="1" TextWrapping="Wrap"/>
        <TextBlock Grid.Row="4" Text="Connections" Foreground="{DynamicResource MutedBrush}"/>
        <TextBlock x:Name="ConnsText" Grid.Row="4" Grid.Column="1"/>
      </Grid>
      <TextBlock Margin="0,12,0,0" Foreground="{DynamicResource MutedBrush}" FontSize="11" TextWrapping="Wrap"
                 Text="Note: Ask is usermode. The first connection may succeed until you Block. Run elevated for immediate WFP enforcement."/>
    </StackPanel>
  </DockPanel>
</Window>

<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <!--
    Dark theme tokens + SystemColors overrides.
    Overriding SystemColors is required so DataGrid/ComboBox/TextBox stop using black text.
  -->

  <!-- App tokens -->
  <Color x:Key="BgColor">#0D1117</Color>
  <Color x:Key="PanelColor">#161B22</Color>
  <Color x:Key="Panel2Color">#21262D</Color>
  <Color x:Key="PanelHoverColor">#30363D</Color>
  <Color x:Key="BorderColor">#30363D</Color>
  <Color x:Key="TextColor">#E6EDF3</Color>
  <Color x:Key="MutedColor">#8B949E</Color>
  <Color x:Key="AccentColor">#2F81F7</Color>
  <Color x:Key="DangerColor">#F85149</Color>
  <Color x:Key="OkColor">#3FB950</Color>
  <Color x:Key="WarnColor">#D29922</Color>
  <Color x:Key="SelectedColor">#1F6FEB</Color>
  <Color x:Key="InputBgColor">#010409</Color>

  <SolidColorBrush x:Key="BgBrush" Color="{StaticResource BgColor}"/>
  <SolidColorBrush x:Key="PanelBrush" Color="{StaticResource PanelColor}"/>
  <SolidColorBrush x:Key="Panel2Brush" Color="{StaticResource Panel2Color}"/>
  <SolidColorBrush x:Key="PanelHoverBrush" Color="{StaticResource PanelHoverColor}"/>
  <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>
  <SolidColorBrush x:Key="TextBrush" Color="{StaticResource TextColor}"/>
  <SolidColorBrush x:Key="MutedBrush" Color="{StaticResource MutedColor}"/>
  <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
  <SolidColorBrush x:Key="AccentTextBrush" Color="#FFFFFF"/>
  <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}"/>
  <SolidColorBrush x:Key="OkBrush" Color="{StaticResource OkColor}"/>
  <SolidColorBrush x:Key="WarnBrush" Color="{StaticResource WarnColor}"/>
  <SolidColorBrush x:Key="SelectedBrush" Color="{StaticResource SelectedColor}"/>
  <SolidColorBrush x:Key="SelectedTextBrush" Color="#FFFFFF"/>
  <SolidColorBrush x:Key="InputBgBrush" Color="{StaticResource InputBgColor}"/>
  <SolidColorBrush x:Key="HeaderBgBrush" Color="{StaticResource Panel2Color}"/>

  <!-- System color overrides (critical for default control templates) -->
  <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="{StaticResource PanelColor}"/>
  <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="{StaticResource TextColor}"/>
  <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="{StaticResource Panel2Color}"/>
  <SolidColorBrush x:Key="{x:Static SystemColors.ControlTextBrushKey}" Color="{StaticResource TextColor}"/>
  <SolidColorBrush x:Key="{x:Static SystemColors.ControlLightBrushKey}" Color="{StaticResource PanelHoverColor}"/>
  <SolidColorBrush x:Key="{x:Static SystemColors.ControlLightLightBrushKey}" Color="{StaticResource PanelHoverColor}"/>
  <SolidColorBrush x:Key="{x:Static SystemColors.ControlDarkBrushKey}" Color="{StaticResource BorderColor}"/>
  <SolidColorBrush x:Key="{x:Static SystemColors.ControlDarkDarkBrushKey}" Color="{StaticResource BgColor}"/>
  <SolidColorBrush x:Key="{x:Static SystemColors.GrayTextBrushKey}" Color="{StaticResource MutedColor}"/>
  <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="{StaticResource SelectedColor}"/>
  <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#FFFFFF"/>
  <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#3D1F6FEB"/>
  <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="{StaticResource TextColor}"/>
  <SolidColorBrush x:Key="{x:Static SystemColors.MenuBrushKey}" Color="{StaticResource PanelColor}"/>
  <SolidColorBrush x:Key="{x:Static SystemColors.MenuTextBrushKey}" Color="{StaticResource TextColor}"/>
  <SolidColorBrush x:Key="{x:Static SystemColors.InfoBrushKey}" Color="{StaticResource Panel2Color}"/>
  <SolidColorBrush x:Key="{x:Static SystemColors.InfoTextBrushKey}" Color="{StaticResource TextColor}"/>
</ResourceDictionary>

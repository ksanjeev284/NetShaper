<Application x:Class="NetShaper.Gui.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
  <Application.Resources>
    <!--
      Theme colors + control styles live in Themes/*.xaml and are loaded by ThemeService.
      App.xaml only bootstraps Dark so the first frame paints correctly before MainWindow ctor.
    -->
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="Themes/Dark.xaml"/>
        <ResourceDictionary Source="Themes/Controls.xaml"/>
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </Application.Resources>
</Application>

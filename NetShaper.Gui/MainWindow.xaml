<Window x:Class="NetShaper.Gui.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="NetShaper — free open-source traffic control"
        Width="1320" Height="880"
        MinWidth="1040" MinHeight="680"
        WindowStartupLocation="CenterScreen"
        Icon="pack://application:,,,/Assets/NetShaper.ico"
        StateChanged="Window_StateChanged"
        Closing="Window_Closing"
        PreviewKeyDown="Window_PreviewKeyDown">
  <DockPanel>
    <!-- Header -->
    <Border DockPanel.Dock="Top" Background="{DynamicResource PanelBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="14,10">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
          <TextBlock Text="NetShaper" FontSize="20" FontWeight="Bold" Margin="0,0,10,0"/>
          <Border Background="#223DDC97" CornerRadius="10" Padding="8,2" VerticalAlignment="Center">
            <TextBlock Text="FREE · MIT" Foreground="{DynamicResource OkBrush}" FontWeight="SemiBold" FontSize="11"/>
          </Border>
          <TextBlock Text="Profile" Foreground="{DynamicResource MutedBrush}" VerticalAlignment="Center" Margin="14,0,6,0"/>
          <ComboBox x:Name="ProfileCombo" Width="130" SelectionChanged="ProfileCombo_SelectionChanged"/>
          <Button Content="＋" Width="32" Click="ProfileNew_Click" ToolTip="New profile" Margin="4,0,0,0" Padding="4,4"/>
          <Button Content="Clone" Click="ProfileClone_Click" Padding="8,4"/>
          <Button Content="Del" Style="{StaticResource DangerButton}" Click="ProfileDelete_Click" Padding="8,4"/>
          <TextBlock x:Name="StatusTotals" Text="" Foreground="{DynamicResource MutedBrush}" Margin="14,0,0,0" VerticalAlignment="Center"/>
        </StackPanel>
        <StackPanel Grid.Column="1" Orientation="Horizontal">
          <CheckBox x:Name="AdminHint" Content="Elevated" IsEnabled="False" VerticalAlignment="Center"/>
          <CheckBox x:Name="ChkLockdown" Content="LOCKDOWN" VerticalAlignment="Center" FontWeight="SemiBold"
                    ToolTip="Catch-all block; only Allow rules pass. Requires Apply WFP."
                    Checked="Lockdown_Changed" Unchecked="Lockdown_Changed"/>
          <CheckBox x:Name="ChkAskMode" Content="ASK" VerticalAlignment="Center" FontWeight="SemiBold"
                    ToolTip="Interactive firewall: prompt when a new app uses the network without a rule."
                    Checked="AskMode_Changed" Unchecked="AskMode_Changed"/>
          <TextBlock x:Name="AskQueueBadge" Text="" VerticalAlignment="Center" Margin="4,0,8,0"
                     Foreground="{DynamicResource WarnBrush}" FontWeight="SemiBold"/>
          <CheckBox x:Name="ChkTopmost" Content="Topmost" VerticalAlignment="Center" Checked="Topmost_Changed" Unchecked="Topmost_Changed"/>
          <Button Content="Refresh" Click="Refresh_Click" ToolTip="F5"/>
          <Button Content="Apply all" Style="{StaticResource AccentButton}" Click="ApplyAll_Click" ToolTip="Ctrl+Shift+A"/>
          <Button Content="WFP" Click="ApplyWfp_Click"/>
          <Button Content="QoS" Click="ApplyQos_Click"/>
          <Button Content="Clear WFP" Style="{StaticResource DangerButton}" Click="ClearWfp_Click"/>
          <Button Content="Clear QoS" Style="{StaticResource DangerButton}" Click="ClearQos_Click"/>
        </StackPanel>
      </Grid>
    </Border>

    <!-- Footer -->
    <Border DockPanel.Dock="Bottom" Background="{DynamicResource PanelBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Padding="14,8">
      <Grid>
        <TextBlock x:Name="StatusBar" Text="Ready." Foreground="{DynamicResource MutedBrush}" TextWrapping="Wrap" Margin="0,0,260,0"/>
        <TextBlock HorizontalAlignment="Right" Foreground="{DynamicResource MutedBrush}" FontSize="11"
                   Text="F5 refresh · Ctrl+Shift+A apply · MIT open source"/>
      </Grid>
    </Border>

    <Grid Margin="10">
      <TabControl x:Name="Tabs">

        <!-- Dashboard -->
        <TabItem Header="Dashboard">
          <Grid Margin="0,10,0,0">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="180"/>
              <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <UniformGrid Columns="6" Margin="0,0,0,12">
              <Border Background="{DynamicResource Panel2Brush}" CornerRadius="8" Padding="12" Margin="0,0,6,0">
                <StackPanel>
                  <TextBlock Text="Download" Foreground="{DynamicResource MutedBrush}" FontSize="11"/>
                  <TextBlock x:Name="DashDown" Text="—" FontSize="20" FontWeight="SemiBold" Foreground="{DynamicResource OkBrush}"/>
                </StackPanel>
              </Border>
              <Border Background="{DynamicResource Panel2Brush}" CornerRadius="8" Padding="12" Margin="0,0,6,0">
                <StackPanel>
                  <TextBlock Text="Upload" Foreground="{DynamicResource MutedBrush}" FontSize="11"/>
                  <TextBlock x:Name="DashUp" Text="—" FontSize="20" FontWeight="SemiBold" Foreground="{DynamicResource AccentBrush}"/>
                </StackPanel>
              </Border>
              <Border Background="{DynamicResource Panel2Brush}" CornerRadius="8" Padding="12" Margin="0,0,6,0">
                <StackPanel>
                  <TextBlock Text="Apps / Conns" Foreground="{DynamicResource MutedBrush}" FontSize="11"/>
                  <TextBlock x:Name="DashApps" Text="—" FontSize="20" FontWeight="SemiBold"/>
                </StackPanel>
              </Border>
              <Border Background="{DynamicResource Panel2Brush}" CornerRadius="8" Padding="12" Margin="0,0,6,0">
                <StackPanel>
                  <TextBlock Text="Rules active" Foreground="{DynamicResource MutedBrush}" FontSize="11"/>
                  <TextBlock x:Name="DashRules" Text="—" FontSize="20" FontWeight="SemiBold"/>
                </StackPanel>
              </Border>
              <Border Background="{DynamicResource Panel2Brush}" CornerRadius="8" Padding="12" Margin="0,0,6,0">
                <StackPanel>
                  <TextBlock Text="Session ↓" Foreground="{DynamicResource MutedBrush}" FontSize="11"/>
                  <TextBlock x:Name="DashSessIn" Text="—" FontSize="16" FontWeight="SemiBold"/>
                </StackPanel>
              </Border>
              <Border Background="{DynamicResource Panel2Brush}" CornerRadius="8" Padding="12">
                <StackPanel>
                  <TextBlock Text="Session ↑" Foreground="{DynamicResource MutedBrush}" FontSize="11"/>
                  <TextBlock x:Name="DashSessOut" Text="—" FontSize="16" FontWeight="SemiBold"/>
                </StackPanel>
              </Border>
            </UniformGrid>

            <Border Grid.Row="1" Background="{DynamicResource PanelBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="8" Margin="0,0,0,12">
              <Grid>
                <TextBlock Text="Rate history (system)" Foreground="{DynamicResource MutedBrush}" FontSize="11" Margin="4,0,0,0"/>
                <Canvas x:Name="RateCanvas" Margin="0,18,0,0" ClipToBounds="True" SizeChanged="RateCanvas_SizeChanged"/>
              </Grid>
            </Border>

            <Grid Grid.Row="2">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
              </Grid.ColumnDefinitions>
              <DockPanel Margin="0,0,8,0">
                <TextBlock DockPanel.Dock="Top" Text="Top talkers" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <!-- Column virtualization can blank bound cells — keep row virt only -->
                <DataGrid x:Name="TopTalkersGrid" EnableRowVirtualization="True" EnableColumnVirtualization="False"
                          HeadersVisibility="Column" GridLinesVisibility="Horizontal">
                  <DataGrid.Columns>
                    <DataGridTextColumn Header="Process / Service" Binding="{Binding DisplayName}" Width="180"/>
                    <DataGridTextColumn Header="↓ rate" Binding="{Binding RateInDisplay}" Width="80"/>
                    <DataGridTextColumn Header="↑ rate" Binding="{Binding RateOutDisplay}" Width="80"/>
                    <DataGridTextColumn Header="↓ data" Binding="{Binding DataInDisplay}" Width="70"/>
                    <DataGridTextColumn Header="↑ data" Binding="{Binding DataOutDisplay}" Width="70"/>
                    <DataGridTextColumn Header="Conns" Binding="{Binding ConnectionCount}" Width="48"/>
                    <DataGridTextColumn Header="Path" Binding="{Binding ExecutablePath}" Width="*"/>
                  </DataGrid.Columns>
                </DataGrid>
              </DockPanel>
              <DockPanel Grid.Column="1">
                <DockPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                  <TextBlock Text="Rule templates" FontWeight="SemiBold" VerticalAlignment="Center"/>
                  <Button Content="Apply selected" DockPanel.Dock="Right" Style="{StaticResource AccentButton}" Click="ApplyTemplate_Click"/>
                </DockPanel>
                <ListBox x:Name="TemplatesList" DisplayMemberPath="Name" Background="{DynamicResource PanelBrush}"
                         BorderBrush="{DynamicResource BorderBrush}" Foreground="{DynamicResource TextBrush}"/>
              </DockPanel>
            </Grid>
          </Grid>
        </TabItem>

        <!-- Live -->
        <TabItem Header="Live traffic">
          <Grid Margin="0,10,0,0">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="2*"/>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="3*"/>
            </Grid.RowDefinitions>
            <DockPanel Margin="0,0,0,8">
              <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                <Button Content="CSV" Click="ExportConnectionsCsv_Click" Margin="0,0,6,0" ToolTip="Export visible connections"/>
                <Button Content="Copy" Click="CopyConnections_Click" Margin="0,0,6,0"/>
                <Button Content="Kill conn" Style="{StaticResource DangerButton}" Click="KillConnection_Click" Margin="0,0,6,0"/>
                <TextBox x:Name="ProcessFilter" Width="160" TextChanged="ProcessFilter_TextChanged" ToolTip="Filter processes"/>
              </StackPanel>
              <TextBlock Text="Processes" FontWeight="SemiBold" VerticalAlignment="Center"/>
            </DockPanel>
            <DataGrid x:Name="ProcessGrid" Grid.Row="1" SelectionChanged="ProcessGrid_SelectionChanged"
                     EnableRowVirtualization="True" EnableColumnVirtualization="False"
                     VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling">
              <DataGrid.Columns>
                <DataGridTextColumn Header="PID" Binding="{Binding ProcessId}" Width="52"/>
                <DataGridTextColumn Header="Process" Binding="{Binding ProcessName}" Width="100"/>
                <DataGridTextColumn Header="Service(s)" Binding="{Binding ServiceNames}" Width="140"/>
                <DataGridTextColumn Header="↓ rate" Binding="{Binding RateInDisplay}" Width="78"/>
                <DataGridTextColumn Header="↑ rate" Binding="{Binding RateOutDisplay}" Width="78"/>
                <DataGridTextColumn Header="↓ data" Binding="{Binding DataInDisplay}" Width="68"/>
                <DataGridTextColumn Header="↑ data" Binding="{Binding DataOutDisplay}" Width="68"/>
                <DataGridTextColumn Header="Conns" Binding="{Binding ConnectionCount}" Width="46"/>
                <DataGridTextColumn Header="Path" Binding="{Binding ExecutablePath}" Width="*"/>
              </DataGrid.Columns>
            </DataGrid>
            <DockPanel Grid.Row="2" Margin="0,10,0,8">
              <Border DockPanel.Dock="Right" Width="160" Height="40" Background="{DynamicResource Panel2Brush}" CornerRadius="6" Margin="12,0,0,0"
                      ToolTip="Per-process rate sparkline (↓ green / ↑ blue)">
                <Canvas x:Name="ProcessSparkCanvas" ClipToBounds="True"/>
              </Border>
              <StackPanel Orientation="Horizontal">
                <Button Content="Block" Style="{StaticResource DangerButton}" Click="BlockSelected_Click"/>
                <Button Content="Allow" Click="AllowSelected_Click"/>
                <Button Content="Limit…" Click="LimitSelected_Click"/>
                <Button Content="Priority" Click="PrioritySelected_Click"/>
                <Button Content="Quota…" Click="QuotaSelected_Click"/>
                <Button Content="Pin" Click="PinProcess_Click" ToolTip="Pin process name for quick filter"/>
                <Button Content="Kill process conns" Click="KillProcessConns_Click"/>
                <TextBlock x:Name="SelectedProcessLabel" Foreground="{DynamicResource MutedBrush}" VerticalAlignment="Center" Margin="8,0,0,0"/>
              </StackPanel>
            </DockPanel>
            <DockPanel Grid.Row="3" Margin="0,0,0,8">
              <TextBlock Text="Connections" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,12,0"/>
              <TextBox x:Name="ConnFilter" Width="140" Margin="0,0,8,0" TextChanged="ConnFilter_TextChanged" ToolTip="Filter remote/local/process"/>
              <ComboBox x:Name="ConnProtoFilter" Width="90" Margin="0,0,8,0" SelectionChanged="ConnFilter_Changed">
                <ComboBoxItem Content="All proto" IsSelected="True"/>
                <ComboBoxItem Content="TCP"/>
                <ComboBoxItem Content="UDP"/>
                <ComboBoxItem Content="TCP6"/>
                <ComboBoxItem Content="UDP6"/>
              </ComboBox>
              <CheckBox x:Name="ChkEstablishedOnly" Content="Established only" VerticalAlignment="Center" Checked="ConnFilter_Changed" Unchecked="ConnFilter_Changed"/>
            </DockPanel>
            <DataGrid x:Name="ConnectionGrid" Grid.Row="4"
                     EnableRowVirtualization="True" EnableColumnVirtualization="False"
                     VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling">
              <DataGrid.Columns>
                <DataGridTextColumn Header="PID" Binding="{Binding ProcessId}" Width="50"/>
                <DataGridTextColumn Header="Process / Service" Binding="{Binding DisplayName}" Width="160"/>
                <DataGridTextColumn Header="Proto" Binding="{Binding Protocol}" Width="48"/>
                <DataGridTextColumn Header="↓ rate" Binding="{Binding RateInDisplay}" Width="72"/>
                <DataGridTextColumn Header="↑ rate" Binding="{Binding RateOutDisplay}" Width="72"/>
                <DataGridTextColumn Header="↓ data" Binding="{Binding DataInDisplay}" Width="64"/>
                <DataGridTextColumn Header="↑ data" Binding="{Binding DataOutDisplay}" Width="64"/>
                <DataGridTextColumn Header="Local" Binding="{Binding LocalEndPoint}" Width="120"/>
                <DataGridTextColumn Header="Remote" Binding="{Binding RemoteEndPoint}" Width="120"/>
                <DataGridTextColumn Header="Host" Binding="{Binding RemoteHost}" Width="110"/>
                <DataGridTextColumn Header="State" Binding="{Binding State}" Width="*"/>
              </DataGrid.Columns>
            </DataGrid>
          </Grid>
        </TabItem>

        <!-- DNS -->
        <TabItem Header="DNS">
          <Grid Margin="0,10,0,0">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="*"/>
              <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <DockPanel Margin="0,0,0,8">
              <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                <Button Content="Refresh cache" Click="DnsRefresh_Click"/>
                <Button Content="Clear" Style="{StaticResource DangerButton}" Click="DnsClear_Click"/>
              </StackPanel>
              <TextBlock x:Name="DnsStatusText" Text="DNS map" FontWeight="SemiBold" VerticalAlignment="Center"/>
            </DockPanel>
            <DataGrid x:Name="DnsGrid" Grid.Row="1">
              <DataGrid.Columns>
                <DataGridTextColumn Header="Host" Binding="{Binding Host}" Width="240"/>
                <DataGridTextColumn Header="IP" Binding="{Binding Ip}" Width="160"/>
                <DataGridTextColumn Header="Updated" Binding="{Binding UpdatedUtc}" Width="160"/>
                <DataGridTextColumn Header="Source" Binding="{Binding Source}" Width="*"/>
              </DataGrid.Columns>
            </DataGrid>
            <Border Grid.Row="2" Background="{DynamicResource Panel2Brush}" CornerRadius="8" Padding="12" Margin="0,10,0,0">
              <StackPanel>
                <TextBlock Text="Domain rule quick add" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                  </Grid.ColumnDefinitions>
                  <TextBox x:Name="DnsDomainBox" Grid.Column="0" Margin="0,0,8,0" ToolTip="e.g. example.com or ads.tracker.net"/>
                  <Button Grid.Column="1" Content="Resolve" Click="DnsResolve_Click"/>
                  <Button Grid.Column="2" Content="Block domain" Style="{StaticResource DangerButton}" Click="DnsBlockDomain_Click"/>
                  <Button Grid.Column="3" Content="Allow domain" Click="DnsAllowDomain_Click"/>
                </Grid>
                <TextBlock Margin="0,8,0,0" Foreground="{DynamicResource MutedBrush}" TextWrapping="Wrap" FontSize="12"
                           Text="Domain rules resolve to IPs and install remote-address WFP filters on Apply. Cache is fed from Windows DNS client cache + reverse lookups of remote IPs. Re-apply WFP after DNS changes for new IPs."/>
              </StackPanel>
            </Border>
          </Grid>
        </TabItem>

        <!-- Rules -->
        <TabItem Header="Rules">
          <Grid Margin="0,10,0,0">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="*"/>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <DockPanel Margin="0,0,0,8">
              <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                <Button Content="Duplicate" Click="DuplicateRule_Click"/>
                <Button Content="Enable" Click="EnableRule_Click"/>
                <Button Content="Disable" Click="DisableRule_Click"/>
                <Button Content="Edit…" Click="EditRule_Click"/>
                <Button Content="Remove" Style="{StaticResource DangerButton}" Click="RemoveRule_Click"/>
                <Button Content="Reload" Click="ReloadPolicy_Click"/>
              </StackPanel>
              <StackPanel Orientation="Horizontal">
                <TextBlock Text="Rules" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBox x:Name="RulesFilter" Width="160" TextChanged="RulesFilter_TextChanged"/>
                <ComboBox x:Name="RulesKindFilter" Width="100" Margin="8,0,0,0" SelectionChanged="RulesFilter_TextChanged">
                  <ComboBoxItem Content="All kinds" IsSelected="True"/>
                  <ComboBoxItem Content="Block"/>
                  <ComboBoxItem Content="Allow"/>
                  <ComboBoxItem Content="Limit"/>
                  <ComboBoxItem Content="Priority"/>
                  <ComboBoxItem Content="Quota"/>
                </ComboBox>
              </StackPanel>
            </DockPanel>
            <DataGrid x:Name="RulesGrid" Grid.Row="1" MouseDoubleClick="RulesGrid_MouseDoubleClick">
              <DataGrid.Columns>
                <DataGridTextColumn Header="Kind" Binding="{Binding Kind}" Width="90"/>
                <DataGridTextColumn Header="Filter" Binding="{Binding FilterName}" Width="150"/>
                <DataGridTextColumn Header="Dir" Binding="{Binding Direction}" Width="50"/>
                <DataGridTextColumn Header="Detail" Binding="{Binding Detail}" Width="100"/>
                <DataGridTextColumn Header="On" Binding="{Binding Enabled}" Width="40"/>
                <DataGridTextColumn Header="Sched" Binding="{Binding ScheduleDisplay}" Width="90"/>
                <DataGridTextColumn Header="Active" Binding="{Binding ActiveNow}" Width="55"/>
                <DataGridTextColumn Header="Matchers" Binding="{Binding Matchers}" Width="*"/>
              </DataGrid.Columns>
            </DataGrid>
            <Border Grid.Row="2" Background="{DynamicResource Panel2Brush}" CornerRadius="8" Padding="10" Margin="0,10,0,0">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="Auto"/>
                  <ColumnDefinition Width="Auto"/>
                  <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="UnblockQuery" Grid.Column="0" Margin="0,0,8,0"/>
                <Button Grid.Column="1" Content="Unblock matching" Style="{StaticResource DangerButton}" Click="UnblockMatching_Click"/>
                <Button Grid.Column="2" Content="Remove all matching" Click="RemoveMatching_Click"/>
                <Button Grid.Column="3" Content="Remove limits" Click="RemoveMatchingLimits_Click"/>
              </Grid>
            </Border>
            <Border Grid.Row="3" Background="{DynamicResource Panel2Brush}" CornerRadius="8" Padding="10" Margin="0,10,0,0">
              <StackPanel>
                <TextBlock Text="Quick add" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="70"/>
                    <ColumnDefinition Width="70"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                  </Grid.ColumnDefinitions>
                  <TextBox x:Name="QuickPath" Grid.Column="0" Margin="0,0,6,0"/>
                  <TextBox x:Name="QuickKbps" Grid.Column="1" Margin="0,0,6,0" Text="1000"/>
                  <TextBox x:Name="QuickQuotaMb" Grid.Column="2" Margin="0,0,6,0" Text="1024"/>
                  <ComboBox x:Name="QuickDir" Grid.Column="3" Margin="0,0,6,0" SelectedIndex="2">
                    <ComboBoxItem Content="In"/>
                    <ComboBoxItem Content="Out"/>
                    <ComboBoxItem Content="Both"/>
                  </ComboBox>
                  <Button Grid.Column="4" Content="Block" Style="{StaticResource DangerButton}" Click="QuickBlock_Click"/>
                  <Button Grid.Column="5" Content="Allow" Click="QuickAllow_Click"/>
                  <Button Grid.Column="6" Content="Limit" Click="QuickLimit_Click"/>
                  <Button Grid.Column="7" Content="Priority" Click="QuickPriority_Click"/>
                  <Button Grid.Column="8" Content="Quota" Click="QuickQuota_Click"/>
                  <Button Grid.Column="9" Content="Ignore lim" Click="QuickIgnoreLimits_Click"/>
                </Grid>
                <Grid Margin="0,8,0,0">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition Width="Auto"/>
                  </Grid.ColumnDefinitions>
                  <TextBlock Text="Matcher" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="{DynamicResource MutedBrush}"/>
                  <ComboBox x:Name="ExtraMatcherKind" Grid.Column="1" Margin="0,0,8,0" SelectedIndex="0">
                    <ComboBoxItem Content="RemotePort"/>
                    <ComboBoxItem Content="LocalPort"/>
                    <ComboBoxItem Content="Domain"/>
                    <ComboBoxItem Content="RemoteCIDR"/>
                    <ComboBoxItem Content="PID"/>
                  </ComboBox>
                  <TextBox x:Name="ExtraPortFrom" Grid.Column="2" Margin="0,0,8,0" Text="443"/>
                  <TextBox x:Name="ExtraPortTo" Grid.Column="3" Margin="0,0,8,0" Text="443"/>
                  <Button Grid.Column="4" Content="Add matcher" Click="AddMatcher_Click"/>
                </Grid>
              </StackPanel>
            </Border>
          </Grid>
        </TabItem>

        <!-- Limits -->
        <TabItem Header="Limits">
          <Grid Margin="0,10,0,0">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="*"/>
              <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <DockPanel Margin="0,0,0,8">
              <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                <TextBlock Text="Mode" VerticalAlignment="Center" Margin="0,0,6,0" Foreground="{DynamicResource MutedBrush}"/>
                <ComboBox x:Name="ShaperModeCombo" Width="130" Margin="0,0,8,0" SelectionChanged="ShaperMode_Changed">
                  <ComboBoxItem Content="Off"/>
                  <ComboBoxItem Content="QoS"/>
                  <ComboBoxItem Content="Soft" IsSelected="True"/>
                  <ComboBoxItem Content="Aggressive"/>
                  <ComboBoxItem Content="Packet"/>
                </ComboBox>
                <Button Content="Probe WinDivert" Click="ProbeWinDivert_Click" ToolTip="Check if WinDivert is installed for Packet mode"/>
                <Button Content="Apply QoS now" Style="{StaticResource AccentButton}" Click="ApplyQos_Click"/>
              </StackPanel>
              <TextBlock x:Name="ShaperStatusText" Text="Bandwidth shaper" FontWeight="SemiBold"/>
            </DockPanel>
            <DataGrid x:Name="LimitsGrid" Grid.Row="1">
              <DataGrid.Columns>
                <DataGridTextColumn Header="Filter" Binding="{Binding FilterName}" Width="160"/>
                <DataGridTextColumn Header="Limit" Binding="{Binding LimitDisplay}" Width="90"/>
                <DataGridTextColumn Header="Measured" Binding="{Binding MeasuredDisplay}" Width="100"/>
                <DataGridTextColumn Header="Over" Binding="{Binding OverLimit}" Width="50"/>
                <DataGridTextColumn Header="Action" Binding="{Binding Action}" Width="110"/>
                <DataGridTextColumn Header="Apps" Binding="{Binding ProcessSummary}" Width="140"/>
                <DataGridTextColumn Header="N" Binding="{Binding MatchedProcesses}" Width="40"/>
                <DataGridTextColumn Header="Matchers" Binding="{Binding Matchers}" Width="*"/>
              </DataGrid.Columns>
            </DataGrid>
            <TextBlock x:Name="LimitsGapText" Grid.Row="2" Margin="0,10,0,0" Foreground="{DynamicResource WarnBrush}" TextWrapping="Wrap"/>
          </Grid>
        </TabItem>

        <!-- Quotas -->
        <TabItem Header="Quotas">
          <Grid Margin="0,10,0,0">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="*"/>
              <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <DockPanel Margin="0,0,0,8">
              <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                <Button Content="Reset selected" Click="ResetQuotaSelected_Click"/>
                <Button Content="Reset all" Style="{StaticResource DangerButton}" Click="ResetQuotaAll_Click"/>
              </StackPanel>
              <TextBlock Text="Quota usage" FontWeight="SemiBold"/>
            </DockPanel>
            <DataGrid x:Name="QuotasGrid" Grid.Row="1">
              <DataGrid.Columns>
                <DataGridTextColumn Header="Filter" Binding="{Binding FilterName}" Width="200"/>
                <DataGridTextColumn Header="Used" Binding="{Binding UsedDisplay}" Width="100"/>
                <DataGridTextColumn Header="Ceiling" Binding="{Binding CeilingDisplay}" Width="100"/>
                <DataGridTextColumn Header="%" Binding="{Binding PercentDisplay}" Width="70"/>
                <DataGridTextColumn Header="Exceeded" Binding="{Binding Exceeded}" Width="80"/>
                <DataGridTextColumn Header="Active" Binding="{Binding ActiveNow}" Width="70"/>
              </DataGrid.Columns>
            </DataGrid>
            <CheckBox x:Name="ChkQuotaAutoBlock" Grid.Row="2" Margin="0,10,0,0" IsChecked="True"
                      Content="Auto-add Block when quota exceeded"/>
          </Grid>
        </TabItem>

        <!-- History / Stats -->
        <TabItem Header="History">
          <Grid Margin="0,10,0,0">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="200"/>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <DockPanel Margin="0,0,0,8">
              <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                <ComboBox x:Name="HistoryRangeCombo" Width="100" SelectionChanged="HistoryRange_Changed">
                  <ComboBoxItem Content="1 hour" IsSelected="True"/>
                  <ComboBoxItem Content="6 hours"/>
                  <ComboBoxItem Content="24 hours"/>
                  <ComboBoxItem Content="7 days"/>
                  <ComboBoxItem Content="30 days"/>
                </ComboBox>
                <Button Content="Refresh" Click="HistoryRefresh_Click"/>
                <Button Content="Export system CSV" Click="HistoryExportSystem_Click"/>
                <Button Content="Export apps CSV" Click="HistoryExportApps_Click"/>
                <Button Content="Purge old" Click="HistoryPurge_Click"/>
                <Button Content="Clear all" Style="{StaticResource DangerButton}" Click="HistoryClear_Click"/>
              </StackPanel>
              <TextBlock x:Name="HistoryInfoText" Text="Stats history" FontWeight="SemiBold" VerticalAlignment="Center"/>
            </DockPanel>
            <Border Grid.Row="1" Background="{DynamicResource PanelBrush}" BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="8" Margin="0,0,0,10">
              <Grid>
                <TextBlock Text="System rate history (↓ green / ↑ blue)" Foreground="{DynamicResource MutedBrush}" FontSize="11"/>
                <Canvas x:Name="HistoryCanvas" Margin="0,18,0,0" ClipToBounds="True" SizeChanged="HistoryCanvas_SizeChanged"/>
              </Grid>
            </Border>
            <DockPanel Grid.Row="2" Margin="0,0,0,8">
              <TextBlock Text="Top apps in range" FontWeight="SemiBold" VerticalAlignment="Center"/>
              <TextBlock x:Name="HistoryRangeLabel" DockPanel.Dock="Right" Foreground="{DynamicResource MutedBrush}" VerticalAlignment="Center"/>
            </DockPanel>
            <DataGrid x:Name="HistoryAppsGrid" Grid.Row="3" MouseDoubleClick="HistoryApps_DoubleClick">
              <DataGrid.Columns>
                <DataGridTextColumn Header="Process" Binding="{Binding Name}" Width="180"/>
                <DataGridTextColumn Header="↓ bytes" Binding="{Binding InDisplay}" Width="110"/>
                <DataGridTextColumn Header="↑ bytes" Binding="{Binding OutDisplay}" Width="110"/>
                <DataGridTextColumn Header="Total" Binding="{Binding TotalDisplay}" Width="110"/>
                <DataGridTextColumn Header="Share" Binding="{Binding ShareDisplay}" Width="*"/>
              </DataGrid.Columns>
            </DataGrid>
          </Grid>
        </TabItem>

        <!-- Filters -->
        <TabItem Header="Filters">
          <Grid Margin="0,10,0,0">
            <TextBlock Text="Policy filters" FontWeight="SemiBold" Margin="0,0,0,8" DockPanel.Dock="Top"/>
            <DataGrid x:Name="FiltersGrid" Margin="0,28,0,0">
              <DataGrid.Columns>
                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="180"/>
                <DataGridTextColumn Header="Zone" Binding="{Binding IsZone}" Width="60"/>
                <DataGridTextColumn Header="Weight" Binding="{Binding Weight}" Width="70"/>
                <DataGridTextColumn Header="Matchers" Binding="{Binding Matchers}" Width="*"/>
                <DataGridTextColumn Header="Id" Binding="{Binding IdShort}" Width="100"/>
              </DataGrid.Columns>
            </DataGrid>
          </Grid>
        </TabItem>

        <!-- Tools -->
        <TabItem Header="Tools">
          <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,10,0,0">
            <StackPanel MaxWidth="900" HorizontalAlignment="Left">
              <TextBlock Text="Search rules across all profiles" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>
              <DockPanel Margin="0,0,0,10">
                <Button Content="Search" DockPanel.Dock="Right" Style="{StaticResource AccentButton}" Click="CrossSearch_Click"/>
                <TextBox x:Name="CrossSearchBox" Margin="0,0,8,0" ToolTip="e.g. chrome, block, 443"/>
              </DockPanel>
              <DataGrid x:Name="CrossSearchGrid" Height="220" Margin="0,0,0,20">
                <DataGrid.Columns>
                  <DataGridTextColumn Header="Profile" Binding="{Binding Profile}" Width="100"/>
                  <DataGridTextColumn Header="Kind" Binding="{Binding Kind}" Width="80"/>
                  <DataGridTextColumn Header="Filter" Binding="{Binding FilterName}" Width="160"/>
                  <DataGridTextColumn Header="On" Binding="{Binding Enabled}" Width="40"/>
                  <DataGridTextColumn Header="Active" Binding="{Binding ActiveNow}" Width="55"/>
                  <DataGridTextColumn Header="Matchers" Binding="{Binding Matchers}" Width="*"/>
                </DataGrid.Columns>
              </DataGrid>

              <TextBlock Text="Pinned processes" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/>
              <DockPanel Margin="0,0,0,8">
                <Button Content="Filter live" DockPanel.Dock="Right" Click="PinnedFilter_Click"/>
                <Button Content="Remove pin" DockPanel.Dock="Right" Click="UnpinSelected_Click"/>
                <ListBox x:Name="PinnedList" Height="100" Background="{DynamicResource PanelBrush}" BorderBrush="{DynamicResource BorderBrush}"/>
              </DockPanel>

              <TextBlock Text="Quick actions" FontSize="16" FontWeight="SemiBold" Margin="0,16,0,10"/>
              <WrapPanel>
                <Button Content="Enable firewall + apply WFP" Click="QuickFirewallOn_Click"/>
                <Button Content="Disable lockdown" Click="QuickLockdownOff_Click"/>
                <Button Content="Clear all rules (keep zones)" Style="{StaticResource DangerButton}" Click="ClearAllRules_Click"/>
                <Button Content="Open ProgramData folder" Click="OpenPolicyFolder_Click"/>
                <Button Content="Copy session summary" Click="CopySessionSummary_Click"/>
              </WrapPanel>

              <TextBlock Text="Session totals" FontSize="16" FontWeight="SemiBold" Margin="0,20,0,10"/>
              <TextBlock x:Name="SessionSummaryText" FontFamily="Consolas" Foreground="{DynamicResource MutedBrush}" TextWrapping="Wrap"/>
            </StackPanel>
          </ScrollViewer>
        </TabItem>

        <!-- Activity -->
        <TabItem Header="Activity">
          <Grid Margin="0,10,0,0">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <DockPanel Margin="0,0,0,8">
              <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                <Button Content="Copy log" Click="CopyActivity_Click"/>
                <Button Content="Clear" Click="ClearActivity_Click"/>
              </StackPanel>
              <TextBlock Text="Activity log" FontWeight="SemiBold"/>
            </DockPanel>
            <DataGrid x:Name="ActivityGrid" Grid.Row="1">
              <DataGrid.Columns>
                <DataGridTextColumn Header="Time" Binding="{Binding TimeDisplay}" Width="150"/>
                <DataGridTextColumn Header="Level" Binding="{Binding Level}" Width="70"/>
                <DataGridTextColumn Header="Message" Binding="{Binding Message}" Width="280"/>
                <DataGridTextColumn Header="Detail" Binding="{Binding Detail}" Width="*"/>
              </DataGrid.Columns>
            </DataGrid>
          </Grid>
        </TabItem>

        <!-- Settings -->
        <TabItem Header="Settings">
          <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0,10,0,0" MaxWidth="780" HorizontalAlignment="Left">
              <TextBlock Text="Features" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12"/>
              <CheckBox x:Name="ChkFirewall" Content="Firewall (WFP block/allow)" Checked="Settings_Changed" Unchecked="Settings_Changed"/>
              <CheckBox x:Name="ChkLimiter" Content="Limiter (bandwidth shaper enabled)" Checked="Settings_Changed" Unchecked="Settings_Changed"/>
              <TextBlock Margin="0,6,0,4" Foreground="{DynamicResource MutedBrush}" Text="Shaper mode (also on Limits tab): Off / QoS / Soft / Aggressive"/>
              <CheckBox x:Name="ChkPriority" Content="Priority (QoS DSCP)" Checked="Settings_Changed" Unchecked="Settings_Changed"/>
              <CheckBox x:Name="ChkQuota" Content="Quota tracking" Checked="Settings_Changed" Unchecked="Settings_Changed"/>
              <CheckBox x:Name="ChkSchedule" Content="Honor schedules on apply" Checked="Settings_Changed" Unchecked="Settings_Changed"/>
              <CheckBox x:Name="ChkStats" Content="Live sampling + write stats history" Checked="Settings_Changed" Unchecked="Settings_Changed"/>
              <CheckBox x:Name="ChkDns" Content="DNS enrichment (hostnames + domain filters)" Margin="0,6,0,0"
                        Checked="DnsEnabled_Changed" Unchecked="DnsEnabled_Changed"/>
              <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                <TextBlock Text="History retention (days)" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox x:Name="StatsRetentionBox" Width="60" Text="30" LostFocus="StatsRetention_Changed"/>
                <CheckBox x:Name="ChkStatsProcesses" Content="Record top processes" Margin="16,0,0,0" IsChecked="True"
                          Checked="GuiPref_Changed" Unchecked="GuiPref_Changed"/>
              </StackPanel>
              <TextBlock x:Name="StatsDbPathText" Margin="0,6,0,0" Foreground="{DynamicResource MutedBrush}" FontFamily="Consolas" FontSize="11" TextWrapping="Wrap"/>
              <CheckBox x:Name="ChkLockdownSettings" Content="Lockdown mode (catch-all block; Allow rules only)" Margin="0,8,0,0"
                        Checked="Lockdown_Changed" Unchecked="Lockdown_Changed"/>
              <TextBlock Text="Ask firewall (interactive)" FontWeight="SemiBold" Margin="0,16,0,8"/>
              <CheckBox x:Name="ChkAskModeSettings" Content="Enable Ask mode (prompt for unknown network apps)"
                        Checked="AskMode_Changed" Unchecked="AskMode_Changed"/>
              <CheckBox x:Name="ChkAskIgnoreSystem" Content="Ignore Windows system processes" Margin="0,6,0,0"
                        Checked="AskOptions_Changed" Unchecked="AskOptions_Changed"/>
              <CheckBox x:Name="ChkAskListeners" Content="Also prompt for Listen/UDP (not only established TCP)" Margin="0,6,0,0"
                        Checked="AskOptions_Changed" Unchecked="AskOptions_Changed"/>
              <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                <Button Content="Clear Ask session decisions" Click="ClearAskSession_Click"/>
                <Button Content="Show pending Ask queue" Click="ShowAskQueue_Click"/>
              </StackPanel>
              <TextBlock Margin="0,8,0,0" Foreground="{DynamicResource MutedBrush}" TextWrapping="Wrap" FontSize="12"
                         Text="Ask is usermode: the first connection may succeed until you Block. Run elevated so Always/Once decisions can apply WFP immediately."/>
              <CheckBox x:Name="ChkPersistWfp" Content="Persistent WFP" Margin="0,12,0,0" Checked="GuiPref_Changed" Unchecked="GuiPref_Changed"/>
              <CheckBox x:Name="ChkApplyOnSave" Content="Auto-apply WFP+QoS after changes (elevated)" Margin="0,8,0,0" Checked="GuiPref_Changed" Unchecked="GuiPref_Changed"/>
              <CheckBox x:Name="ChkTray" Content="Minimize to tray" Margin="0,8,0,0" IsChecked="True" Checked="GuiPref_Changed" Unchecked="GuiPref_Changed"/>
              <CheckBox x:Name="ChkToasts" Content="Toast notifications" Margin="0,8,0,0" IsChecked="True" Checked="GuiPref_Changed" Unchecked="GuiPref_Changed"/>
              <CheckBox x:Name="ChkEStats" Content="TCP EStats rates" Margin="0,8,0,0" IsChecked="True" Checked="EStats_Changed" Unchecked="EStats_Changed"/>
              <CheckBox x:Name="ChkStartup" Content="Start with Windows" Margin="0,8,0,0" Checked="Startup_Changed" Unchecked="Startup_Changed"/>
              <CheckBox x:Name="ChkStartMin" Content="Start minimized to tray" Margin="0,8,0,0" Checked="GuiPref_Changed" Unchecked="GuiPref_Changed"/>
              <CheckBox x:Name="ChkCompact" Content="Compact mode (smaller grids)" Margin="0,8,0,0" Checked="Compact_Changed" Unchecked="Compact_Changed"/>

              <TextBlock Text="Theme" Margin="0,16,0,6" FontWeight="SemiBold"/>
              <StackPanel Orientation="Horizontal">
                <ComboBox x:Name="ThemeCombo" Width="140" SelectionChanged="Theme_Changed">
                  <ComboBoxItem Content="Dark" IsSelected="True"/>
                  <ComboBoxItem Content="Light"/>
                </ComboBox>
              </StackPanel>

              <TextBlock Text="Refresh interval (seconds)" Margin="0,16,0,6" FontWeight="SemiBold"/>
              <StackPanel Orientation="Horizontal">
                <Slider x:Name="RefreshSlider" Width="220" Minimum="0.5" Maximum="5" Value="1.5" TickFrequency="0.5"
                        IsSnapToTickEnabled="True" ValueChanged="RefreshSlider_Changed"/>
                <TextBlock x:Name="RefreshLabel" Margin="12,0,0,0" VerticalAlignment="Center" Text="1.5 s"/>
              </StackPanel>

              <TextBlock Text="Rate alert threshold (Mb/s, 0=off)" Margin="0,16,0,6" FontWeight="SemiBold"/>
              <StackPanel Orientation="Horizontal">
                <TextBox x:Name="AlertMbpsBox" Width="80" Text="0" LostFocus="AlertThreshold_Changed"/>
                <TextBlock Margin="10,0,0,0" VerticalAlignment="Center" Foreground="{DynamicResource MutedBrush}"
                           Text="Toast when total ↓+↑ exceeds this"/>
              </StackPanel>

              <TextBlock Text="Status" FontSize="16" FontWeight="SemiBold" Margin="0,24,0,12"/>
              <Border Background="{DynamicResource Panel2Brush}" CornerRadius="8" Padding="12">
                <StackPanel>
                  <TextBlock x:Name="WfpStatusText" FontFamily="Consolas" FontSize="11" TextWrapping="Wrap"/>
                  <TextBlock x:Name="QosStatusText" FontFamily="Consolas" FontSize="11" TextWrapping="Wrap" Margin="0,10,0,0"/>
                  <Button Content="Refresh status" Margin="0,10,0,0" HorizontalAlignment="Left" Click="RefreshWfpStatus_Click"/>
                </StackPanel>
              </Border>

              <TextBlock Text="Windows Service" FontSize="16" FontWeight="SemiBold" Margin="0,24,0,12"/>
              <Border Background="{DynamicResource Panel2Brush}" CornerRadius="8" Padding="12">
                <StackPanel>
                  <TextBlock x:Name="ServiceStatusText" FontFamily="Consolas" FontSize="11" TextWrapping="Wrap"/>
                  <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                    <Button Content="Refresh service" Click="RefreshService_Click"/>
                    <Button Content="Scripts folder" Click="OpenScriptsFolder_Click"/>
                  </StackPanel>
                </StackPanel>
              </Border>

              <TextBlock Text="Access control (ACL)" FontSize="16" FontWeight="SemiBold" Margin="0,24,0,12"/>
              <Border Background="{DynamicResource Panel2Brush}" CornerRadius="8" Padding="12" Margin="0,0,0,8">
                <StackPanel>
                  <TextBlock x:Name="AccessCurrentText" FontFamily="Consolas" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,8"/>
                  <CheckBox x:Name="ChkAclEnabled" Content="Enforce ACL (when off, everyone has full access)"
                            Checked="AclEnabled_Changed" Unchecked="AclEnabled_Changed"/>
                  <CheckBox x:Name="ChkAclAdmins" Content="Local Administrators always get full access" Margin="0,6,0,0"
                            Checked="AclAdmins_Changed" Unchecked="AclAdmins_Changed"/>
                  <DataGrid x:Name="AclGrid" Height="120" Margin="0,10,0,8">
                    <DataGrid.Columns>
                      <DataGridTextColumn Header="Principal" Binding="{Binding Principal}" Width="180"/>
                      <DataGridTextColumn Header="Rights" Binding="{Binding Allowed}" Width="140"/>
                      <DataGridTextColumn Header="SID" Binding="{Binding Sid}" Width="*"/>
                    </DataGrid.Columns>
                  </DataGrid>
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="140"/>
                      <ColumnDefinition Width="Auto"/>
                      <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="AclPrincipalBox" Margin="0,0,8,0" ToolTip="DOMAIN\user or .\User"/>
                    <ComboBox x:Name="AclRightsBox" Grid.Column="1" Margin="0,0,8,0" SelectedIndex="3">
                      <ComboBoxItem Content="Monitor"/>
                      <ComboBoxItem Content="Control"/>
                      <ComboBoxItem Content="RemoteApi"/>
                      <ComboBoxItem Content="All"/>
                      <ComboBoxItem Content="Monitor,RemoteApi"/>
                    </ComboBox>
                    <Button Grid.Column="2" Content="Add / update" Click="AclAdd_Click"/>
                    <Button Grid.Column="3" Content="Remove selected" Style="{StaticResource DangerButton}" Click="AclRemove_Click"/>
                  </Grid>
                  <TextBlock Margin="0,8,0,0" Foreground="{DynamicResource MutedBrush}" FontSize="11" TextWrapping="Wrap"
                             Text="Monitor=view only · Control=change policy / apply / kill · RemoteApi=host may serve HTTP API. Enabling ACL auto-adds you with All."/>
                </StackPanel>
              </Border>

              <TextBlock Text="Local HTTP API" FontSize="16" FontWeight="SemiBold" Margin="0,24,0,12"/>
              <Border Background="{DynamicResource Panel2Brush}" CornerRadius="8" Padding="12">
                <StackPanel>
                  <CheckBox x:Name="ChkApiEnabled" Content="Enable local API (this process)" Checked="ApiEnabled_Changed" Unchecked="ApiEnabled_Changed"/>
                  <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                    <TextBlock Text="Port" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBox x:Name="ApiPortBox" Width="80" Text="8741" LostFocus="ApiSettings_Changed"/>
                    <Button Content="Copy URL" Margin="12,0,0,0" Click="ApiCopyUrl_Click"/>
                    <Button Content="Copy API key" Click="ApiCopyKey_Click"/>
                    <Button Content="Regenerate key" Style="{StaticResource DangerButton}" Click="ApiRegenKey_Click"/>
                  </StackPanel>
                  <TextBlock x:Name="ApiStatusText" Margin="0,10,0,0" FontFamily="Consolas" FontSize="11" TextWrapping="Wrap"
                             Foreground="{DynamicResource MutedBrush}"/>
                </StackPanel>
              </Border>

              <TextBlock Text="Remote API (mTLS)" FontSize="16" FontWeight="SemiBold" Margin="0,24,0,12"/>
              <Border Background="{DynamicResource Panel2Brush}" CornerRadius="8" Padding="12">
                <StackPanel>
                  <CheckBox x:Name="ChkRemoteApi" Content="Enable remote HTTPS API with client certificates"
                            Checked="RemoteApi_Changed" Unchecked="RemoteApi_Changed"/>
                  <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                    <TextBlock Text="Port" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBox x:Name="RemotePortBox" Width="80" Text="8742" LostFocus="RemoteApiSettings_Changed"/>
                    <TextBlock Text="Host name" VerticalAlignment="Center" Margin="12,0,8,0"/>
                    <TextBox x:Name="RemoteHostBox" Width="140" LostFocus="RemoteApiSettings_Changed"/>
                    <CheckBox x:Name="ChkRemoteNonLocal" Content="Listen on all interfaces" Margin="12,0,0,0"
                              Checked="RemoteApiSettings_Changed" Unchecked="RemoteApiSettings_Changed"/>
                  </StackPanel>
                  <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                    <Button Content="Ensure CA+server certs" Click="CertsEnsure_Click"/>
                    <Button Content="Issue client cert…" Click="CertsIssue_Click"/>
                    <Button Content="Open certs folder" Click="CertsFolder_Click"/>
                  </StackPanel>
                  <TextBlock x:Name="RemoteApiStatusText" Margin="0,10,0,0" FontFamily="Consolas" FontSize="11" TextWrapping="Wrap"
                             Foreground="{DynamicResource MutedBrush}"/>
                  <TextBlock Margin="0,8,0,0" Foreground="{DynamicResource MutedBrush}" FontSize="11" TextWrapping="Wrap"
                             Text="mTLS: each client needs a issued .pfx + API key. Cert password (dev): NetShaper-Dev-ChangeMe. Multi-client sessions: GET /api/v1/sessions"/>
                </StackPanel>
              </Border>

              <TextBlock Text="Kernel driver (optional)" FontSize="16" FontWeight="SemiBold" Margin="0,24,0,12"/>
              <Border Background="{DynamicResource Panel2Brush}" CornerRadius="8" Padding="12">
                <StackPanel>
                  <TextBlock x:Name="DriverStatusText" FontFamily="Consolas" FontSize="11" TextWrapping="Wrap"/>
                  <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                    <Button Content="Refresh driver status" Click="DriverStatus_Click"/>
                    <Button Content="Push limits to driver" Click="DriverPush_Click"/>
                    <Button Content="Open driver docs" Click="DriverDocs_Click"/>
                  </StackPanel>
                  <TextBlock Margin="0,8,0,0" Foreground="{DynamicResource MutedBrush}" FontSize="11" TextWrapping="Wrap"
                             Text="Build with WDK (driver\README.md). Test-sign: scripts\enable-testsigning.ps1 + install-driver-testsign.ps1. Production needs EV signing + Microsoft attestation."/>
                </StackPanel>
              </Border>

              <TextBlock Text="Policy / profiles" FontSize="16" FontWeight="SemiBold" Margin="0,24,0,12"/>
              <TextBlock Margin="0,0,0,8" Foreground="{DynamicResource MutedBrush}">
                <Run Text="Active file: "/>
                <Run x:Name="PolicyPathRun" FontFamily="Consolas"/>
              </TextBlock>
              <WrapPanel>
                <Button Content="Open folder" Click="OpenPolicyFolder_Click"/>
                <Button Content="View JSON" Click="ViewPolicyJson_Click"/>
                <Button Content="Export…" Click="ExportPolicy_Click"/>
                <Button Content="Import…" Click="ImportPolicy_Click"/>
                <Button Content="Copy path" Click="CopyPolicyPath_Click"/>
                <Button Content="Reset defaults" Click="ResetPolicy_Click"/>
              </WrapPanel>

              <TextBlock Text="About" FontSize="16" FontWeight="SemiBold" Margin="0,24,0,12"/>
              <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource MutedBrush}" LineHeight="20"
                         Text="NetShaper is free open-source traffic control for Windows (MIT). Uses IP Helper, WFP, NetQos, and optional WinDivert."/>
            </StackPanel>
          </ScrollViewer>
        </TabItem>
      </TabControl>
    </Grid>
  </DockPanel>
</Window>

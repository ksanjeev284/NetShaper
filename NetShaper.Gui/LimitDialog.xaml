<Window x:Class="NetShaper.Gui.LimitDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add limit" SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource PanelBrush}">
  <StackPanel Margin="20" MinWidth="320">
    <TextBlock x:Name="TitleText" FontWeight="SemiBold" Margin="0,0,0,12"/>
    <TextBlock Text="Limit (kbps)" Foreground="{DynamicResource MutedBrush}" Margin="0,0,0,4"/>
    <TextBox x:Name="KbpsBox" Text="1000" Margin="0,0,0,16"/>
    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
      <Button Content="Cancel" IsCancel="True" Click="Cancel_Click"/>
      <Button Content="Add limit" Style="{StaticResource AccentButton}" IsDefault="True" Click="Ok_Click"/>
    </StackPanel>
  </StackPanel>
</Window>
